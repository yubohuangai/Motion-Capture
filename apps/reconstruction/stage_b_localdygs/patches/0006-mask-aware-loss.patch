-        return img, self.image_poses[index], self.image_times[index] 
+        # Try to load mask from sibling masks/ dir.
+        # image_paths[index] is like <scene>/frame<N>/images/<cam>.jpg;
+        # mask is at <scene>/frame<N>/masks/<cam>.{jpg,png}.
+        # If no masks/ dir, mask stays None and the loss is computed
+        # over the whole image (standard 3DGS behavior).
+        mask = None
+        ip = self.image_paths[index]
+        mask_dir = os.path.dirname(os.path.dirname(ip)) + "/masks"
+        if os.path.isdir(mask_dir):
+            stem = os.path.splitext(os.path.basename(ip))[0]
+            for ext in (".png", ".jpg", ".jpeg"):
+                mp = os.path.join(mask_dir, stem + ext)
+                if os.path.exists(mp):
+                    mask_img = Image.open(mp).convert("L")
+                    if self.downsample != 1.0:
+                        mask_img = mask_img.resize(
+                            self.img_whs[int(index / self.N_frames)],
+                            Image.NEAREST,
+                        )
+                    mask = self.transform(mask_img)  # (1, H, W) in [0,1]
+                    # Threshold to binary so JPEG artifacts don't leak in
+                    mask = (mask > 0.5).float()
+                    break
+
+        return img, self.image_poses[index], self.image_times[index], mask
     
 
